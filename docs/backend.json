{
  "entities": {
    "PaymentVoucher": {
      "title": "PaymentVoucher",
      "type": "object",
      "description": "Represents a single payment voucher in the Tropical Ledger system.",
      "properties": {
        "voucherNo": { "type": "string" },
        "date": { "type": "string" },
        "recipient": { "type": "string" },
        "amountRO": { "type": "number" },
        "amountBz": { "type": "number" },
        "sumInWords": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "purpose": { "type": "string" },
        "ledgerId": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Ledger": {
      "title": "Ledger",
      "type": "object",
      "description": "Represents a spreadsheet sheet or ledger category.",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/vouchers/{voucherId}": {
      "schema": "PaymentVoucher",
      "description": "Collection of all financial payment vouchers."
    },
    "/ledgers/{ledgerId}": {
      "schema": "Ledger",
      "description": "Collection of spreadsheet sheets/ledgers."
    }
  }
}