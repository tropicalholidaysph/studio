
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal access rule for authenticated users.
    // This allows anonymous sessions to manage the ledger and its sheets.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v12.0.0 - Broad authentication clearance
  }
}
