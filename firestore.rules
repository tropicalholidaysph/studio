rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicit rules for the Tropical Ledger collections
    match /vouchers/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /ledgers/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /authorizedUsers/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Fallback for any other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}