rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tropical Ledger Security Rules
    // Allow authenticated users (including anonymous) full access to vouchers and ledgers
    match /vouchers/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /ledgers/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Allow all other documents for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}