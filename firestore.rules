rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to the collections used in the code
    match /vouchers/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /ledgers/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Generic fallback for any other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger version: v2.0.9
  }
}