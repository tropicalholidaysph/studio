rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Universal access for any authenticated user in Tropical Ledger
    // This resolves the list/read permission loops by ensuring broad coverage
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger comment: v2.0.1
  }
}