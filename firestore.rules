rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tropical Ledger Security Rules
    // Allowing all authenticated users full access to vouchers and ledgers for the MVP.
    
    match /vouchers/{voucherId} {
      allow read, write: if request.auth != null;
    }
    
    match /ledgers/{ledgerId} {
      allow read, write: if request.auth != null;
    }

    // Highly permissive rules for all other documents for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}